{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "backroom-poker-live",
  "main": "multiplayer/worker.ts",
  "compatibility_date": "2026-05-22",
  "durable_objects": {
    "bindings": [
      { "name": "LOBBY", "class_name": "PokerLobby" },
      { "name": "TABLES", "class_name": "PokerTable" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["PokerLobby", "PokerTable"] }
  ],
  "observability": { "enabled": true }
}
